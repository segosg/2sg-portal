---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="About">
  <Nav slot="nav" />

  <section class="max-w-3xl mx-auto px-6 pt-32 pb-24">

    <p class="font-mono text-forge-secondary text-sm mb-4">~/about</p>
    <h1 class="font-mono text-4xl font-bold text-forge-heading mb-12">À propos</h1>

    <!-- CE QUE JE CONSTRUIS -->
    <div class="mb-16">
      <p class="font-mono text-xs text-forge-muted tracking-widest uppercase mb-6">// ce que je construis</p>

      <p class="font-sans text-forge-body leading-relaxed mb-4">
        Je travaille à l'intersection de la <span class="text-forge-heading">data engineering</span> et du <span class="text-forge-heading">product management</span> — deux disciplines que je pratique à parts égales, dans des contextes grands comptes où la complexité est réelle et les enjeux concrets.
      </p>

      <p class="font-sans text-forge-body leading-relaxed mb-4">
        Mon terrain de jeu actuel : les <span class="text-forge-heading">LLMs, les agents et l'IA appliquée</span>. Pas l'IA comme buzzword — l'IA comme levier opérationnel, intégrée dans des pipelines data solides, au service de produits qui délivrent vraiment.
      </p>

      <p class="font-sans text-forge-body leading-relaxed border-l-2 border-forge-primary pl-4 mt-8">
        La data reste la fondation. Avant les modèles, avant les agents, avant les démos impressionnantes — il y a des pipelines, des schémas, des contrats de données. C'est moins vendeur que l'IA. C'est pourtant ce qui fait tenir l'édifice. C'est aussi ça, mon combat.
      </p>
    </div>

    <!-- MANIÈRE DE TRAVAILLER -->
    <div class="mb-16">
      <p class="font-mono text-xs text-forge-muted tracking-widest uppercase mb-6">// manière de travailler</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <div class="border border-forge-border rounded-lg p-5 bg-forge-surface">
          <p class="font-mono text-forge-primary text-sm mb-2">Craft avant tout</p>
          <p class="font-sans text-forge-body text-sm leading-relaxed">Bien faire les choses, même quand personne ne regarde. La qualité d'une architecture data se voit six mois plus tard.</p>
        </div>

        <div class="border border-forge-border rounded-lg p-5 bg-forge-surface">
          <p class="font-mono text-forge-primary text-sm mb-2">Technique & produit</p>
          <p class="font-sans text-forge-body text-sm leading-relaxed">Je passe sans friction du schéma de BDD à la roadmap produit. Les deux se nourrissent — l'un sans l'autre produit rarement quelque chose d'utile.</p>
        </div>

        <div class="border border-forge-border rounded-lg p-5 bg-forge-surface">
          <p class="font-mono text-forge-primary text-sm mb-2">Expérimenter en public</p>
          <p class="font-sans text-forge-body text-sm leading-relaxed">Ce site est un laboratoire. Les projets du Lab sont des expériences réelles — pas des démos, des outils que j'utilise.</p>
        </div>

        <div class="border border-forge-border rounded-lg p-5 bg-forge-surface">
          <p class="font-mono text-forge-primary text-sm mb-2">Pragmatisme</p>
          <p class="font-sans text-forge-body text-sm leading-relaxed">La meilleure solution est celle qui fonctionne dans le contexte réel, pas dans le contexte idéal. Grands comptes = contraintes fortes = créativité forcée.</p>
        </div>

      </div>
    </div>

    <!-- CE SITE -->
    <div>
      <p class="font-mono text-xs text-forge-muted tracking-widest uppercase mb-6">// ce site</p>
      <p class="font-sans text-forge-body leading-relaxed">
        2sg.io est construit avec <span class="text-forge-heading">Astro</span>, stylisé avec <span class="text-forge-heading">Tailwind</span>, hébergé sur <span class="text-forge-heading">Vercel</span>. Le Lab tourne sur <span class="text-forge-heading">Supabase</span>. Tout est versionné sur <span class="text-forge-heading">GitHub</span>. Le site évolue en continu — comme les projets qu'il documente.
      </p>
    </div>

  </section>

  <Footer slot="footer" />
</BaseLayout>