---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Logo from '../components/Logo.astro';

const cards = [
  { href: '/blog', label: '~/blog', title: 'Blog',  desc: 'Réflexions sur la data, le product et l\'ingénierie.' },
  { href: '/lab',  label: '~/lab',  title: 'Lab',   desc: 'Expériences, outils et prototypes en cours.'         },
  { href: '/cv',   label: '~/cv',   title: 'CV',    desc: 'Parcours, compétences et expériences.'               },
];
---
<BaseLayout title="Home">
  <Nav slot="nav" />

  <section class="relative min-h-screen flex flex-col justify-center px-6 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, #3DFF9A 2px, #3DFF9A 3px);">
    </div>
    <div class="pointer-events-none absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-10"
         style="background: radial-gradient(ellipse, #3DFF9A 0%, transparent 70%); filter: blur(60px);">
    </div>

    <div class="max-w-5xl mx-auto w-full pt-20">

        <!-- Logo -->
        <Logo />

        <!-- Prompt line -->
        <p class="font-mono text-forge-muted text-sm mb-8 animate-fade-up">
            <span class="text-forge-primary">➜</span>
            <span class="ml-2">2sg.io</span>
            <span class="text-forge-secondary ml-2">git:(main)</span>
            <span class="ml-2">✦</span>
        </p>

      <h1 class="font-mono text-4xl sm:text-6xl font-bold leading-[1.05] tracking-tight mb-6 animate-fade-up">
        <span class="text-forge-heading">Analytics </span><span class="text-forge-primary">&</span><span class="text-forge-heading"> AI Engineering</span><br />
        <span class="text-forge-primary">Feat</span>
        <span class="text-forge-heading"> Product Management</span>
        </h1>

      <p class="font-mono text-forge-body text-lg sm:text-xl mt-6 mb-12 animate-fade-up">
        <span class="text-forge-secondary">// </span>Forge de solutions data & IA
        <span class="inline-block w-[2px] h-5 bg-forge-primary align-middle ml-1 animate-blink"></span>
      </p>

      <div class="flex flex-wrap gap-4 animate-fade-up">
        <a href="/lab"
           class="font-mono text-sm px-5 py-2.5 bg-forge-primary text-forge-bg font-bold rounded hover:opacity-90 transition-opacity">
          ./explorer-le-lab
        </a>
        <a href="/about"
           class="font-mono text-sm px-5 py-2.5 border border-forge-border text-forge-heading rounded hover:border-forge-primary hover:text-forge-primary transition-colors duration-200">
          ./à-propos
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs text-forge-muted mb-8 tracking-widest uppercase">— Sections</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {cards.map(({ href, label, title, desc }) => (
          <a href={href}
             class="group relative block border border-forge-border rounded-lg p-6 bg-forge-surface hover:border-forge-primary transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_#3DFF9A18]">
            <p class="font-mono text-xs text-forge-secondary mb-4">{label}</p>
            <h2 class="font-mono text-2xl font-bold text-forge-heading mb-2 group-hover:text-forge-primary transition-colors duration-200">
              {title}
            </h2>
            <p class="font-sans text-sm text-forge-body leading-relaxed">{desc}</p>
            <span class="font-mono text-forge-primary text-sm mt-4 inline-block opacity-0 group-hover:opacity-100 transition-opacity duration-200">
              cd ./{title.toLowerCase()} →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>